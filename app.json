{
  "expo": {
    "name": "Manvue",
    "slug": "manvue",
    "version": "1.1.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "manvue",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.meritoriouslegalhr.manvue2",
      "buildNumber": "8",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Manvue accesses your photo library so you can upload profile pictures, resumes, or portfolio images when applying for jobs.",
        "NSPhotoLibraryAddUsageDescription": "Manvue may save images such as interview screenshots or shared media to your photo library.",
        "NSCameraUsageDescription": "Manvue uses the camera so users can participate in video interviews and capture profile photos when applying for jobs.",
        "NSMicrophoneUsageDescription": "Manvue uses the microphone so users can speak during video interviews and send voice responses to employers.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        },
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "v9wttpbfk9.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "n38lu8286q.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "4s89h6z0as.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "4468km3ulz.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "238zf685vr.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "22mmun2rn5.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "4dzt52r2t5.skadnetwork"
          },
          {
            "SKAdNetworkIdentifier": "578prtvx9j.skadnetwork"
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.meritoriouslegalhr.manvue2",
      "versionCode": 7,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Manvue uses the camera so users can participate in video interviews and capture profile photos for job applications.",
          "microphonePermission": "Manvue uses the microphone so users can speak during video interviews and record voice responses for employers.",
          "recordAudioAndroid": true
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-video",
        {
          "supportsPictureInPicture": true
        }
      ],
      [
        "react-native-fbsdk-next",
        {
          "appID": "713059878427310",
          "clientToken": "3b9fbd1b4ba5e92b7b042bf0f5458117",
          "displayName": "Manvue",
          "scheme": "fb713059878427310",
          "advertiserIDCollectionEnabled": true,
          "autoLogAppEventsEnabled": true,
          "isAutoInitEnabled": true,
          "iosUserTrackingPermission": "This identifier will be used to deliver personalized ads to you."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "bridgelessEnabled": false
          },
          "ios": {
            "newArchEnabled": true,
            "bridgelessEnabled": false
          }
        }
      ],
      "expo-tracking-transparency"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e973ffe0-fd55-45c7-813b-3c10852bf1ea"
      }
    }
  }
